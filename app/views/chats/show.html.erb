<div class="container mt-5">
  <%= link_to "← Back to MacroChef", root_path, class: "d-inline-block mb-3" %>

  <h1 class="mc-heading mb-4">MacroChef Chat</h1>

  <% @chat.messages.each do |message| %>
    <% plan = meal_plan_payload(message) %>

    <% if plan %>
      <% profile = plan["profile"] %>

      <div class="mb-4">
        <h2 class="mc-heading h6 mb-3">Your Meal Plan</h2>

        <div class="mc-surface p-4 mb-3">
          <div class="row row-cols-2 row-cols-md-4 g-3 text-center">
            <div class="col">
              <div class="stat-value"><%= profile["target_kcal"] %></div>
              <div class="stat-label">kcal / day</div>
            </div>
            <div class="col">
              <div class="stat-value"><%= profile["protein_g"] %>g</div>
              <div class="stat-label"><span class="macro-dot protein"></span>Protein</div>
            </div>
            <div class="col">
              <div class="stat-value"><%= profile["carbs_g"] %>g</div>
              <div class="stat-label"><span class="macro-dot carbs"></span>Carbs</div>
            </div>
            <div class="col">
              <div class="stat-value"><%= profile["fat_g"] %>g</div>
              <div class="stat-label"><span class="macro-dot fat"></span>Fat</div>
            </div>
          </div>
        </div>

        <p class="mb-3">
          <span class="badge bg-secondary text-capitalize"><%= profile["diet_type"] %></span>
          <span class="badge bg-secondary text-capitalize"><%= profile["goal"].to_s.tr("_", " ") %></span>
          <% Array(profile["allergies"]).each do |allergy| %>
            <span class="badge bg-danger-subtle text-danger-emphasis"><%= allergy %>-free</span>
          <% end %>
        </p>

        <% if profile["assumptions"].present? %>
          <div class="alert alert-info small">
            <strong>Assumptions made:</strong>
            <ul class="mb-0">
              <% profile["assumptions"].each do |assumption| %>
                <li><%= assumption %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="accordion" id="plan-accordion-<%= message.id %>">
          <% plan["week"].each_with_index do |day, index| %>
            <% totals = day_totals(day) %>
            <% target_kcal = profile["target_kcal"].to_f %>
            <% pct = target_kcal.positive? ? [totals[:kcal] / target_kcal, 1.0].min : 0 %>

            <div class="accordion-item mc-surface mb-2">
              <h2 class="accordion-header">
                <button
                  class="accordion-button <%= "collapsed" unless index.zero? %>"
                  type="button"
                  data-bs-toggle="collapse"
                  data-bs-target="#day-<%= message.id %>-<%= index %>"
                >
                  <span class="mc-heading"><%= day["day"] %></span>
                </button>
              </h2>
              <div
                id="day-<%= message.id %>-<%= index %>"
                class="accordion-collapse collapse <%= "show" if index.zero? %>"
                data-bs-parent="#plan-accordion-<%= message.id %>"
              >
                <div class="accordion-body">
                  <div class="row g-4 align-items-center mb-4">
                    <div class="col-auto">
                      <div class="calorie-ring" style="--pct: <%= pct %>">
                        <div class="calorie-ring-value">
                          <div class="stat-value"><%= totals[:kcal] %></div>
                          <div class="stat-label">/ <%= profile["target_kcal"] %> kcal</div>
                        </div>
                      </div>
                    </div>
                    <div class="col">
                      <% [
                           ["Protein", :protein_g, profile["protein_g"], "protein"],
                           ["Carbs",   :carbs_g,   profile["carbs_g"],   "carbs"],
                           ["Fat",     :fat_g,     profile["fat_g"],     "fat"]
                         ].each do |label, key, target, modifier| %>
                        <% target = target.to_f %>
                        <% ratio = target.positive? ? [(totals[key] / target) * 100, 100].min : 0 %>
                        <div class="macro-row">
                          <div class="macro-row-header">
                            <span class="macro-row-label"><span class="macro-dot <%= modifier %>"></span><%= label %></span>
                            <span class="macro-row-value"><%= totals[key] %> / <%= target.to_i %> g</span>
                          </div>
                          <div class="macro-bar-track">
                            <div class="macro-bar-fill <%= modifier %>" style="width: <%= ratio %>%"></div>
                          </div>
                        </div>
                      <% end %>
                    </div>
                  </div>

                  <% day["meals"].each do |meal| %>
                    <div class="meal-row">
                      <div class="meal-row-icon">
                        <%= { "breakfast" => "🍳", "lunch" => "🥗", "dinner" => "🍽", "snack" => "🍎" }.fetch(meal["meal_type"], "🍴") %>
                      </div>
                      <div class="meal-row-body">
                        <div class="meal-row-type"><%= meal["meal_type"] %></div>
                        <div class="meal-row-title"><%= meal["name"] %></div>
                        <div class="meal-row-macros">
                          <%= meal["kcal"] %> kcal · P<%= meal["protein_g"] %> C<%= meal["carbs_g"] %> F<%= meal["fat_g"] %>
                        </div>

                        <ul class="small mb-1 mt-2 list-unstyled">
                          <% Array(meal["ingredients"]).each do |ingredient| %>
                            <li class="d-flex justify-content-between gap-2">
                              <span class="text-secondary-mc">• <%= ingredient["quantity"] %><%= ingredient["unit"] %> <%= ingredient["name"] %></span>
                              <span class="text-secondary-mc text-nowrap">
                                <%= ingredient["kcal"] %> kcal · P<%= ingredient["protein_g"] %> C<%= ingredient["carbs_g"] %> F<%= ingredient["fat_g"] %>
                              </span>
                            </li>
                          <% end %>
                        </ul>

                        <ol class="small mb-0 ps-3 text-secondary-mc">
                          <% Array(meal["steps"]).each do |step| %>
                            <li><%= step %></li>
                          <% end %>
                        </ol>
                      </div>
                    </div>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>

    <% else %>
      <div class="mb-3">
        <strong><%= message.role.capitalize %></strong>
        <div class="mc-surface p-3">
          <%= simple_format(message.content) %>
        </div>
      </div>
    <% end %>
  <% end %>
</div>
