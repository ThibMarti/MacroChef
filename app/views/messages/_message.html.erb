<% if message.role == "user" %>
  <div class="d-flex justify-content-end mb-2">
    <div class="bg-light border rounded p-3">
      <%= simple_format(message.content) %>
    </div>
  </div>
<% else %>
  <div class="d-flex justify-content-start mb-3">
    <div class="border rounded p-3">
      <%= simple_format(message.content) %>
    </div>
  </div>
<% end %>
