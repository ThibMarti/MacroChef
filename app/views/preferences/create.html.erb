<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">
      <h1 class="mc-heading mb-1">Confirm your targets</h1>
      <p class="text-secondary-mc mb-4">
        Calculated from your body data. Edit grams or the % directly — grams recalculate
        calories (and re-normalize the split), while editing a % only rescales that macro
        against the current calories, so the total below shows if your % add up to 100.
      </p>

      <%= form_with url: generate_preferences_path, method: :post, data: { turbo: false },
            html: { onsubmit: "this.querySelector('button[type=submit]').disabled = true; this.querySelector('button[type=submit]').textContent = 'Generating your meal plan… (this can take up to a minute)';" } do %>
        <div class="mc-surface p-4 mb-4" data-controller="macro-calculator">
          <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
              <div class="stat-value" data-macro-calculator-target="kcal"><%= @target_kcal %></div>
              <div class="stat-label">kcal / day</div>
            </div>
            <div class="text-end">
              <div class="stat-value" data-macro-calculator-target="totalPct">100%</div>
              <div class="stat-label">total split</div>
            </div>
          </div>

          <div class="row g-3">
            <div class="col-12">
              <label class="form-label" for="protein_g"><span class="macro-dot protein"></span>Protein</label>
              <div class="row g-2">
                <div class="col-7">
                  <div class="input-group">
                    <input type="number" step="1" min="0" class="form-control" name="protein_g" id="protein_g"
                           value="<%= @protein_g %>" data-macro-calculator-target="protein"
                           data-action="input->macro-calculator#recalculateFromGrams">
                    <span class="input-group-text">g</span>
                  </div>
                </div>
                <div class="col-5">
                  <div class="input-group">
                    <input type="number" step="1" min="0" class="form-control" data-macro="protein"
                           data-macro-calculator-target="proteinPct"
                           data-action="input->macro-calculator#recalculateFromPercent">
                    <span class="input-group-text">%</span>
                  </div>
                </div>
              </div>
            </div>
            <div class="col-12">
              <label class="form-label" for="carbs_g"><span class="macro-dot carbs"></span>Carbs</label>
              <div class="row g-2">
                <div class="col-7">
                  <div class="input-group">
                    <input type="number" step="1" min="0" class="form-control" name="carbs_g" id="carbs_g"
                           value="<%= @carbs_g %>" data-macro-calculator-target="carbs"
                           data-action="input->macro-calculator#recalculateFromGrams">
                    <span class="input-group-text">g</span>
                  </div>
                </div>
                <div class="col-5">
                  <div class="input-group">
                    <input type="number" step="1" min="0" class="form-control" data-macro="carbs"
                           data-macro-calculator-target="carbsPct"
                           data-action="input->macro-calculator#recalculateFromPercent">
                    <span class="input-group-text">%</span>
                  </div>
                </div>
              </div>
            </div>
            <div class="col-12">
              <label class="form-label" for="fat_g"><span class="macro-dot fat"></span>Fat</label>
              <div class="row g-2">
                <div class="col-7">
                  <div class="input-group">
                    <input type="number" step="1" min="0" class="form-control" name="fat_g" id="fat_g"
                           value="<%= @fat_g %>" data-macro-calculator-target="fat"
                           data-action="input->macro-calculator#recalculateFromGrams">
                    <span class="input-group-text">g</span>
                  </div>
                </div>
                <div class="col-5">
                  <div class="input-group">
                    <input type="number" step="1" min="0" class="form-control" data-macro="fat"
                           data-macro-calculator-target="fatPct"
                           data-action="input->macro-calculator#recalculateFromPercent">
                    <span class="input-group-text">%</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <%= hidden_field_tag "preference[gender]", @calculator_params[:gender] %>
        <%= hidden_field_tag "preference[weight_kg]", @calculator_params[:weight_kg] %>
        <%= hidden_field_tag "preference[body_fat_percent]", @calculator_params[:body_fat_percent] %>
        <%= hidden_field_tag "preference[steps_per_day]", @calculator_params[:steps_per_day] %>
        <%= hidden_field_tag "preference[training_type]", @calculator_params[:training_type] %>
        <%= hidden_field_tag "preference[training_minutes]", @calculator_params[:training_minutes] %>
        <%= hidden_field_tag "preference[training_days_per_week]", @calculator_params[:training_days_per_week] %>
        <%= hidden_field_tag "preference[goal]", @calculator_params[:goal] %>
        <%= hidden_field_tag "preference[extra_notes]", @calculator_params[:extra_notes] %>
        <%= hidden_field_tag "preference[only_favorites]", @calculator_params[:only_favorites] %>
        <%= hidden_field_tag "preference[recurring_breakfast_id]", @calculator_params[:recurring_breakfast_id] %>
        <%= hidden_field_tag "preference[recurring_lunch_id]", @calculator_params[:recurring_lunch_id] %>
        <%= hidden_field_tag "preference[recurring_dinner_id]", @calculator_params[:recurring_dinner_id] %>
        <%= hidden_field_tag "preference[recurring_snack_1_id]", @calculator_params[:recurring_snack_1_id] %>
        <%= hidden_field_tag "preference[recurring_snack_2_id]", @calculator_params[:recurring_snack_2_id] %>

        <div class="d-flex gap-2">
          <%= link_to "← Back", new_preference_path, class: "btn btn-outline-secondary" %>
          <button type="submit" class="btn btn-primary btn-lg flex-grow-1">Generate my meal plan</button>
        </div>
      <% end %>
    </div>
  </div>
</div>
