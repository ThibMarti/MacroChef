<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Macro Chef" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Macro Chef">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <script>
      // Applied synchronously, before CSS/paint, to avoid a flash of the
      // wrong theme. Mirrors the fallback logic in theme_controller.js.
      // Light is always the default unless the user explicitly toggled to
      // dark before (we don't follow the OS preference).
      (function () {
        var theme = localStorage.getItem("macrochef-theme") || "light";
        document.documentElement.setAttribute("data-theme", theme);
      })();
    </script>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>

    <%= link_to "Skip to main content", "#main-content", class: "visually-hidden-focusable" %>

    <%= render "shared/flashes" %>

    <header>
      <%= render "shared/navbar" %>
    </header>

    <main id="main-content">
      <%= yield %>
    </main>
  </body>
</html>
